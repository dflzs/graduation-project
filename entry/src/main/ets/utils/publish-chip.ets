export function getPublishChipBackground(selected: boolean): string {
  return selected ? '#F1EDE7' : '#FFFFFF';
}

export function getPublishChipBorder(selected: boolean): string {
  return selected ? '#D4CCBF' : '#E5DDD2';
}

export function getPublishChipText(selected: boolean): string {
  return selected ? '#3D3935' : '#676058';
}
