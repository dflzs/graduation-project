export function getCartSelectionOuterFill(selected: boolean): string {
  return selected ? '#E8F0FF' : '#FFFFFF';
}

export function getCartSelectionOuterBorder(selected: boolean): string {
  return selected ? '#D9E6FF' : '#FFFFFF';
}

export function getCartSelectionInnerFill(selected: boolean): string {
  return selected ? '#2F6BFF' : '#FFFFFF';
}

export function getCartSelectionInnerBorder(selected: boolean): string {
  return selected ? '#2F6BFF' : '#B7B0A6';
}

export function getCartCardBackground(selected: boolean): string {
  return selected ? '#F3F7FF' : '#FFFDFC';
}

export function getCartCardBorder(selected: boolean): string {
  return selected ? '#BFD3FF' : '#E7DED2';
}
